# ==================== BROKERAGE CONFIGURATION ====================


# ==================== SWING TRADING PARAMETERS ====================
# Position Sizing (Aggressive but Manageable)
SWING_POSITION_SIZE=0.15           # 15% per position (was 25%)
SWING_STOP_LOSS=0.05               # 5% stop loss (was 10%)
SWING_TAKE_PROFIT=0.12             # 12% take profit (was 8%)
MAX_POSITIONS=4                    # Max 4 positions = 60% deployed

# ==================== REALISTIC TARGETS ====================
# Quarterly Targets (Aggressive but Achievable)
QUARTERLY_PROFIT_TARGET=0.15       # 15% per quarter = 60% annually
QUARTERLY_MAX_LOSS=0.10            # Max 10% loss per quarter
MONTHLY_PROFIT_TARGET=0.05         # 5% per month = 60% annually
MONTHLY_MAX_LOSS=0.04              # Max 4% loss per month

# ==================== RISK MANAGEMENT ====================
# Portfolio Risk (Aggressive but Controlled)
MAX_PORTFOLIO_RISK=0.20            # Max 20% total risk (was 40%)
MIN_WIN_RATE=0.50                  # Realistic 50% win rate
RISK_REWARD_RATIO=2.4              # 2.4:1 R:R (12% profit / 5% loss)
MAX_DAILY_LOSS=0.02                # 2% max daily loss
MAX_CONSECUTIVE_LOSSES=3           # Stop after 3 losses in a row

# Position Management
TRAILING_STOP=0.08                 # Trail stop at 8% profit
PARTIAL_PROFIT_TAKE=0.50           # Take 50% off at first target
FIRST_PROFIT_TARGET=0.06           # First target at 6% (1.2:1)
SECOND_PROFIT_TARGET=0.12          # Second target at 12% (2.4:1)

# ==================== SCANNING PARAMETERS ====================
# Fundamental Filters
MIN_MARKET_CAP=500000000           # $500M min (was $100M - too small)
MIN_VOLUME=2000000                 # 2M shares daily (was 1M)
MIN_PRICE=10.0                     # $10 min (was $5 - avoid penny stocks)
MAX_PRICE=300.0                    # $300 max (was $500)

# Technical Filters (Aggressive Momentum)
MIN_MOMENTUM=8.0                   # 8% momentum (was 15%)
MAX_RSI=85                         # Max RSI 85 (very strong trends, watch closely)
MIN_RSI=50                         # Min RSI 50 (strong uptrend confirmation)
MIN_VOLUME_RATIO=2.0               # 2x average volume (smart money confirmation)
MOMENTUM_LOOKBACK_DAYS=10          # 10-day momentum (was 20)

# Pattern Recognition
REQUIRE_UPTREND=true               # Only trade with trend
MIN_ADX=25                         # Trend strength indicator
VOLUME_CONFIRMATION=true           # Require volume on breakout

# ==================== ENTRY RULES ====================
# Entry Confirmation
MIN_BULLISH_SIGNALS=3              # Need 3+ bullish indicators
ALLOW_PULLBACK_ENTRY=true          # Enter on pullbacks in uptrend
MAX_DISTANCE_FROM_SUPPORT=0.03     # Max 3% above support level

# Entry Timing
MARKET_OPEN_BUFFER=30              # Wait 30min after open
MARKET_CLOSE_BUFFER=30             # Stop trading 30min before close
AVOID_EARNINGS_DAYS=true           # Don't trade into earnings

# ==================== EXIT RULES ====================
# Profit Taking Strategy
USE_SCALING_OUT=true               # Scale out in portions
FIRST_EXIT_SIZE=0.50               # Exit 50% at first target
SECOND_EXIT_SIZE=0.30              # Exit 30% at second target
RUNNER_SIZE=0.20                   # Let 20% run with trail

# Stop Loss Management
USE_TRAILING_STOP=true             # Activate after 6% profit
TRAILING_STOP_ACTIVATION=0.06      # Activate trail at 6%
TRAILING_STOP_DISTANCE=0.03        # Trail 3% below high
MOVE_STOP_TO_BE_AT=0.04            # Move to breakeven at 4%

# Time-Based Exits
MAX_HOLD_DAYS=15                   # Exit after 15 days
EXIT_ON_FRIDAY=false               # Optional: close before weekend

# ==================== ADVANCED RISK CONTROLS ====================
# Correlation Management
MAX_CORRELATED_POSITIONS=2         # Max 2 positions in correlated stocks
CORRELATION_THRESHOLD=0.70         # Consider correlated if >0.70

# Volatility Filters
MAX_BETA=2.0                       # Max beta 2.0 vs SPY
MIN_ATR_MULTIPLIER=1.5             # Min 1.5x ATR for stop distance
MAX_IV_PERCENTILE=80               # Max 80% IV percentile

# Market Conditions
REQUIRE_MARKET_UPTREND=true        # Only trade when SPY trending up
MAX_VIX=30                         # Don't trade if VIX > 30
CHECK_SECTOR_STRENGTH=true         # Verify sector is strong

# ==================== BACKTESTING PARAMETERS ====================
BACKTEST_START_DATE=2022-01-01
BACKTEST_END_DATE=2024-12-31
BACKTEST_INITIAL_CAPITAL=50000
BACKTEST_COMMISSION=0.001          # $1 per $1000 traded

# ==================== NOTIFICATIONS ====================
ENABLE_TRADE_ALERTS=true
ENABLE_DAILY_SUMMARY=true
ENABLE_RISK_ALERTS=true
ALERT_EMAIL=your_email@example.com
ALERT_WEBHOOK_URL=your_webhook_url

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/trading.log
SAVE_TRADE_HISTORY=true
TRADE_HISTORY_PATH=./data/trades.csv
