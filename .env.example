# ============================================================
# AUTO TRADER — Required Environment Variables
# ============================================================
# Copy this file to .env for local runs (never commit .env)
# For GitHub Actions: add each key under Settings → Secrets → Actions
# ============================================================

# --- Alpaca Paper Trading (free at alpaca.markets) ----------
# Go to: alpaca.markets → Log in → Paper Trading → API Keys
APCA_API_KEY_ID=your_paper_api_key_here
APCA_API_SECRET_KEY=your_paper_secret_key_here

# --- Polygon.io (free tier — 5 calls/min) -------------------
# Go to: polygon.io → Sign up free → Dashboard → API Keys
POLYGON_API_KEY=your_polygon_api_key_here

# --- Optional data feeds ------------------------------------
# finnhub.io free tier (60 calls/min)
FINNHUB_API_KEY=your_finnhub_key_here

# eodhd.com free tier (20 EOD requests/day)
EODHD_API_KEY=your_eodhd_key_here
